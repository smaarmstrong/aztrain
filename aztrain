def cmd_teardown(args):
    """Delete rg-aztrain-* resource groups — the ONLY thing in this repo that
    ever destroys cloud state, and it refuses to touch any other name."""
    if not args:
        die("usage: aztrain teardown <id> [<id>...] | --all")
    pin = pinned_sub()
    if not pin:
        die(f"no pinned subscription in {PIN_FILE} — nothing safe to tear down")
    active = active_sub()
    if not active or active.lower() != pin.lower():
        die(f"active subscription is not the pinned training one — refusing. "
            f"Switch with: az account set -s {pin}")
    if "--all" in args:
        rc, out = az(["group", "list", "--query",
                      f"[?starts_with(name, '{RG_PREFIX}')].name", "-o", "json"], timeout=60)
        if rc != 0:
            die("could not list resource groups")
        names = json.loads(out)
    else:
        tasks = discover()
        names = [rg_for(resolve(tasks, a)) for a in args]
    if not names:
        print(GRN("nothing to tear down — no rg-aztrain-* groups exist"))
        invalidate_rg_cache()
        return
    for name in sorted(set(names)):
        if not name.startswith(RG_PREFIX):   # belt and braces
            die(f"refusing to delete '{name}' — not an aztrain resource group")
        rc, _ = az(["group", "show", "-n", name, "-o", "none"], timeout=30)
        if rc != 0:
            print(DIM(f"  · {name} (does not exist, skipped)"))
            continue
        rc, out = az(["group", "delete", "-n", name, "--yes", "--no-wait"], timeout=60)
        if rc == 0:
            print(GRN(f"  ✓ {name} deletion started"))
        else:
            print(RED(f"  ✗ {name}: {out or 'delete failed'}"))
    invalidate_rg_cache()
    print(DIM("deletions run in the background; re-run `aztrain status` later to confirm"))

# ---- learn: an interactive tutor -------------------------------------------
def ask(msg):
    """Prompt the learner; treat a closed stdin (piped/non-interactive) as Enter."""
    try:
        return input(msg).strip().lower()
    except EOFError:
        print()
        return ""

def parse_lesson(text):
    """Split a lesson into a sequence of beats the tutor walks through:
        ('prose', text)         a chunk of the lecture, printed as-is
        ('pause', None)         a `---` line — wait for the learner
        ('run',  (tag, lines))  a fenced command block to try
    A lesson with none of these markers is one prose beat.

    Three run fences are recognised. ```run is a step the tutor MAY run for the
    learner (only if it classifies as local & read-only — see block_is_cloud);
    ```run-manual and ```az are ALWAYS present-only, for commands the learner
    must run themselves. Lines are captured VERBATIM (indentation/blanks kept)
    so heredocs and multi-line snippets survive as one block."""
    beats, buf, lines, i = [], [], text.splitlines(), 0
    def flush():
        if any(l.strip() for l in buf):
            beats.append(("prose", "\n".join(buf).strip("\n")))
        buf.clear()
    while i < len(lines):
        s = lines[i].strip()
        tag = s[3:].strip() if s.startswith("```") else ""
        if s == "---":
            flush(); beats.append(("pause", None)); i += 1
        elif tag in ("run", "run-manual", "az"):
            flush(); raw = []; i += 1
            while i < len(lines) and not lines[i].strip().startswith("```"):
                raw.append(lines[i]); i += 1      # verbatim — keep indentation
            i += 1                                 # skip the closing fence
            while raw and not raw[0].strip():  raw.pop(0)    # trim blank edges
            while raw and not raw[-1].strip(): raw.pop()
            if raw:
                beats.append(("run", (tag, raw)))
        else:
            buf.append(lines[i]); i += 1
    flush()
    return beats

# az subcommands that only read version info or compile Bicep locally — no
# authentication, no cloud call, no cost. Everything else az does is treated as
# cloud (present-only). Keep this list tight; when in doubt, leave it out.
SAFE_AZ = {"--version", "version", "bicep build", "bicep version",
           "bicep format", "bicep lint", "bicep decompile"}
_AZ_CALL = re.compile(r"(?:^|[|;&(]|\s)az\s+(--version|[a-z][a-z-]*(?:\s+[a-z][a-z-]*)?)")

def block_is_cloud(lines):
    """True if a run block would authenticate to Azure, mutate cloud resources,
    or cost money — so the tutor must PRESENT it for the learner to run under
    their own login, never auto-fire it. Safe-by-default: anything not
    positively recognised as local & read-only is treated as cloud.

    THIS is aztrain's key divergence from the redhat/pytrain tutors, whose run
    blocks execute on a throwaway machine. Here they'd hit the learner's real
    subscription, so `az login`, `az group create`, `az deployment ... create`
    etc. are never run for them."""
    for ln in lines:
        code = ln.split("#", 1)[0]
        for m in _AZ_CALL.finditer(code):
            if m.group(1).strip() not in SAFE_AZ:
                return True
        if re.search(r"\b(azd|terraform|pulumi|kubectl|helm)\b", code):
            return True
        if re.search(r"\bbicep\s+(deploy|publish|restore)\b", code):
            return True
    return False

def run_lesson(beats, cwd=None):
    """Walk the learner through a parsed lesson. Prose is paced with pauses.
    A run block that is local & read-only can be run here (Enter), typed by the
    learner in a real shell (t), skipped (s) or the lesson quit (q). A cloud
    block is only shown — the learner runs it themselves (t opens a shell under
    their own az login). Returns False if the learner quit early."""
    for kind, payload in beats:
        if kind == "prose":
            print(payload)
        elif kind == "pause":
            if ask(DIM("\n  [Enter to continue · q to stop] ")) in ("q", "quit"):
                return False
            print()
        elif kind == "run":
            tag, lines = payload
            manual = tag in ("run-manual", "az") or block_is_cloud(lines)
            print()
            if manual:
                print(BLD("  Run this yourself") + DIM("  (under your own az login — "
                          "aztrain won't touch the cloud for you):"))
            else:
                print(BLD("  Your turn — run this:"))
            for line in lines:
                print(GRN("    " + line))
            if manual:
                ans = ask(DIM("  [Enter to continue · t to open a shell and run it "
                              "· s skip · q stop] "))
            else:
                ans = ask(DIM("  [Enter to run it here · t to type it yourself "
                              "· s skip · q stop] "))
            if ans in ("q", "quit"):
                return False
            if ans in ("s", "skip"):
                continue
            if ans in ("t", "type"):
                print(DIM("  Shell open — type the command above yourself "
                          "(Tab autocompletes)."))
                print(DIM("  Run it, then `exit` (or Ctrl-D) to come back to the lesson."))
                subprocess.run(["bash", "-i"], cwd=cwd)
                print(DIM("  ── back to the lesson " + "─" * 26))
                continue
            if manual:
                continue                       # Enter on a cloud block: never run it
            print(DIM("  ── output " + "─" * 40))
            subprocess.run(["bash", "-c", "\n".join(lines)], cwd=cwd)
            print(DIM("  " + "─" * 49))
    return True

def _offer_practice(st, tid, meta, short, is_cloud):
    """Close a lesson by handing off to a solo attempt."""
    if is_cloud:
        print(DIM("This task provisions real Azure resources — start it when you're "
                  "ready\n(your az login, your bill):  ") + f"{SELF} start {short}")
        return
    if ask(BLD("Set it up so you can try it now? ")
           + DIM("[Enter = yes, q = later] ")) not in ("q", "quit"):
        launch_task(st, tid, meta, provision=True)
    else:
        print(DIM("When you're ready:  ") + f"{SELF} start {short}")

def cmd_learn(args):
    """Teach a task like a tutor: a paced lecture from learn.md that tells you
    what to run as you go, then hands off to a solo attempt. With no id it
    teaches the next new task — the same one `train` would give you."""
    tasks = discover()
    st = load_state()
    if args:
        tid = resolve(tasks, args[0])
    else:
        nxt = next_new(tasks, st, cloud_ready())
        if nxt is None:
            print(DIM("You've started every task already. Revisit a lesson with:  ")
                  + f"{SELF} learn <id>")
            return
        tid = nxt[0]
    meta = tasks[tid]
    short = leaf_of(tid)
    is_cloud = meta.get("kind", "local") != "local"
    print(BLD(f"\nLESSON — {meta.get('domain', domain_of(tid))}: {meta['title']}")
          + DIM(f"  [{tid}]"))
    print(DIM(f"objective: {meta.get('objective','')}"))
    print("─" * 60)

    # Local tasks: scaffold a workspace to follow along in (safe, local, and it
    # becomes the current task). Cloud tasks: NEVER provision during a lesson —
    # teaching is read-only; provisioning is the learner's explicit `start`.
    ws = ws_dir(tid)
    if not is_cloud:
        ws = populate_workspace(tid, meta)
        mark_current(st, tid)
    else:
        ws.mkdir(parents=True, exist_ok=True)

    lesson = meta["_dir"] / "learn.md"
    if not lesson.exists():
        print(DIM("No written lesson for this task yet — read the spec, give it a"))
        print(DIM("go, and reveal a worked solution with  ") + f"{INVOKE} solution")
        print("\n" + (meta["_dir"] / "prompt.md").read_text().rstrip())
        print("─" * 60)
        _offer_practice(st, tid, meta, short, is_cloud)
        return

    if is_cloud:
        print(YEL("This is a cloud task — the commands below are ones you run "
                  "YOURSELF, under\nyour own az login. aztrain never runs az for "
                  "you or provisions during a lesson.\n"))
    finished = run_lesson(parse_lesson(lesson.read_text()), cwd=str(ws))
    print("─" * 60)
    if not finished:
        print(DIM("Lesson paused. Pick it back up any time:  ") + f"{SELF} learn {short}")
        return
    print(GRN("That's the lesson.")
          + DIM("  Best way to make it stick is to do it yourself."))
    _offer_practice(st, tid, meta, short, is_cloud)

COMMANDS = {
    "learn": cmd_learn, "train": cmd_train, "next": cmd_train,
    "list": cmd_list, "start": cmd_start, "check": cmd_check,
    "solution": cmd_solution, "reset": cmd_reset, "status": cmd_status,
    "teardown": cmd_teardown,
}

def main():
    if sys.version_info < MIN_PY:
        die(f"aztrain needs Python >= {'.'.join(map(str, MIN_PY))}")
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        print(__doc__.strip())
        return
    fn = COMMANDS.get(args[0])
    if not fn:
        die(f"unknown command '{args[0]}' (try: aztrain help)")
    fn(args[1:])

if __name__ == "__main__":
    main()
