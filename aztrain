#!/usr/bin/env python3
"""
aztrain — a console trainer for the Azure certification pathway (AZ-104 → AZ-400).

Each task is a real job, not a flashcard: author Bicep that must compile to the
right ARM JSON, write KQL/JMESPath queries graded against canned fixtures, or —
for live tasks — fix real Azure state in a disposable resource group, graded by
read-only `az` queries on the END STATE (any correct fix passes).

Usage:
    aztrain learn [id]             # teach the next new task like a tutor, then hand off
    aztrain train                  # auto-pick what to do next (a review, or new material)
    aztrain list [track|domain]    # all tasks, grouped, with your status
    aztrain start  <id>            # set up the task (live: provisions its RG) and show the spec
    aztrain check  [id]            # grade it (defaults to the task you're on)
    aztrain solution [id]          # reveal the reference solution (defaults to current)
    aztrain reset  [id]            # restore the starter scaffold (defaults to current)
    aztrain status                 # XP, streak, per-domain completion
    aztrain teardown <id>|--all    # delete rg-aztrain-* resource groups (the ONLY destroyer)

New to Azure?  Run `aztrain learn` — it explains the concept behind the next
task, then sets it up so you can try it. Once you know the ropes, `aztrain
train` just picks what to practise next (new material in a fundamentals-first
order, or a spaced-repetition review) so you don't have to decide.

<id> is "track/domain/nn-name" or any unique trailing "nn-name" / "name". For
check/solution/reset you can omit it to act on the task train/start gave you.

SAFETY RAILS
    * Cloud-touching tasks (kind "whatif"/"live") refuse to run unless the active
      az subscription equals the one pinned in ~/.config/aztrain/subscription.
      Task setup/00-subscription-safety walks you through creating that pin.
    * Every live task works inside its own resource group rg-aztrain-<task>,
      created by its setup.sh and destroyed only by `aztrain teardown`.
    * Graders only ever READ cloud state. Tasks marked est_cost "paid" refuse
      to start without an explicit --i-am-paying flag.

Local tasks need only Python >= 3.11 and (for Bicep tasks) `az bicep install`.
Progress is stored in ~/.local/state/aztrain/progress.json.
"""
import json
import os
import re
import shutil
import subprocess
import sys
import time
from datetime import date, timedelta
from pathlib import Path

REPO = Path(__file__).resolve().parent
TASKS = REPO / "tasks"
WORKSPACE = REPO / "workspace"
STATE_DIR = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local/state")) / "aztrain"
STATE = STATE_DIR / "progress.json"
RG_CACHE = STATE_DIR / "rgcheck.json"
PIN_FILE = Path(os.environ.get("AZTRAIN_PIN_FILE",
                Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "aztrain/subscription"))
RG_PREFIX = "rg-aztrain-"
LOCATION = os.environ.get("AZTRAIN_LOCATION", "uksouth")
MIN_PY = (3, 11)
GUID = re.compile(r"^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$", re.I)

# How the learner invoked us, so hints name a command they can actually run.
# SELF is the runnable path (e.g. ./aztrain) — used for hints that take an <id>
# (start/reset/teardown/solution <id>). INVOKE is what to suggest for the plain
# verbs: `make <verb>` when run under make (MAKELEVEL is set), else the same
# path. Only the parameterless verbs have make targets, so id-bearing hints
# always use SELF — no hint ever names a command the learner can't run.
SELF = sys.argv[0] or "./aztrain"
INVOKE = "make" if os.environ.get("MAKELEVEL") else SELF

# ---- colours ---------------------------------------------------------------
_tty = sys.stdout.isatty()
def c(code, s):
    return f"\033[{code}m{s}\033[0m" if _tty else s
GRN = lambda s: c("32", s)
RED = lambda s: c("31", s)
YEL = lambda s: c("33", s)
BLU = lambda s: c("34", s)
MAG = lambda s: c("35", s)
DIM = lambda s: c("2", s)
BLD = lambda s: c("1", s)

XP_BY_DIFFICULTY = {1: 10, 2: 15, 3: 25, 4: 40, 5: 60}
KINDS = ("local", "whatif", "live")
COSTS = ("free", "pennies", "paid")

# ---- state -----------------------------------------------------------------
def load_state():
    try:
        st = json.loads(STATE.read_text())
    except (FileNotFoundError, json.JSONDecodeError):
        st = {"tasks": {}, "xp": 0, "streak": {"count": 0, "last": ""}}
    # Fields added by train/learn; backfill so older progress files still load.
    st.setdefault("current", None)
    st.setdefault("recent_picks", [])
    return st

def save_state(st):
    STATE.parent.mkdir(parents=True, exist_ok=True)
    STATE.write_text(json.dumps(st, indent=2))

def bump_streak(st):
    today = date.today()
    s = st["streak"]
    if s["last"] == today.isoformat():
        return
    if s.get("last") and date.fromisoformat(s["last"]) == today - timedelta(days=1):
        s["count"] += 1
    else:
        s["count"] = 1
    s["last"] = today.isoformat()

# ---- spaced repetition -----------------------------------------------------
# Days until the next review, indexed by how many times you've passed the task.
# After the table runs out we keep roughly doubling. Same ladder as the redhat
# and pytrain trainers: quick early reinforcement, then widening gaps.
REVIEW_INTERVALS = [1, 3, 7, 16, 35, 75]

def review_interval(reps):
    """Days until the next review after `reps` successful passes (reps >= 1)."""
    i = max(reps, 1) - 1
    if i < len(REVIEW_INTERVALS):
        return REVIEW_INTERVALS[i]
    return REVIEW_INTERVALS[-1] * (2 ** (i - len(REVIEW_INTERVALS) + 1))

def days_overdue(iso_due):
    """How many days past its review date a task is (>=0 means due now).
    None if it has no scheduled review yet."""
    if not iso_due:
        return None
    return date.today().toordinal() - date.fromisoformat(iso_due).toordinal()

def schedule_review(entry, reps):
    """Record the next review date `review_interval(reps)` days out."""
    entry["reps"] = reps
    due = date.fromordinal(date.today().toordinal() + review_interval(reps))
    entry["due"] = due.isoformat()

# ---- task discovery --------------------------------------------------------
def discover():
    """Return {task_id: meta_dict} for every task, sorted. IDs are the task
    dir path relative to tasks/ — "az104/networking/01-nsg-allow-https" or
    "setup/00-subscription-safety"."""
    tasks = {}
    if not TASKS.is_dir():
        return tasks
    for meta_path in sorted(TASKS.glob("**/meta.json")):
        d = meta_path.parent
        tid = d.relative_to(TASKS).as_posix()
        try:
            meta = json.loads(meta_path.read_text())
        except json.JSONDecodeError as e:
            print(YEL(f"warning: bad meta.json in {tid}: {e}"), file=sys.stderr)
            continue
        meta["_dir"] = d
        tasks[tid] = meta
    return tasks

def resolve(tasks, ident):
    """Accept a full id, or a unique trailing 'nn-name' / 'name'."""
    ident = ident.strip("/")
    if ident in tasks:
        return ident
    hits = [t for t in tasks if t.endswith("/" + ident)]
    if not hits:
        hits = [t for t in tasks if re.sub(r"^\d+-", "", t.rsplit("/", 1)[-1]) == ident]
    if len(hits) == 1:
        return hits[0]
    if len(hits) > 1:
        die(f"'{ident}' is ambiguous: {', '.join(hits)}")
    die(f"no task called '{ident}' (try: aztrain list)")

def die(msg):
    print(RED(f"error: {msg}"), file=sys.stderr)
    sys.exit(1)

def domain_of(tid):
    return tid.rsplit("/", 1)[0]

def leaf_of(tid):
    return tid.rsplit("/", 1)[-1]

def rg_for(tid):
    return RG_PREFIX + leaf_of(tid)

# ---- az plumbing -----------------------------------------------------------
def az(args, timeout=60):
    """Run az, return (rc, stdout). Never raises on nonzero exit."""
    if not shutil.which("az"):
        die("the `az` CLI is not installed (https://aka.ms/azure-cli)")
    p = subprocess.run(["az", *args], capture_output=True, text=True,
                       stdin=subprocess.DEVNULL, timeout=timeout)
    return p.returncode, p.stdout.strip()

def pinned_sub():
    """The subscription GUID pinned by setup/00, or None."""
    try:
        for line in PIN_FILE.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#"):
                return line if GUID.match(line) else None
    except FileNotFoundError:
        pass
    return None

def active_sub():
    rc, out = az(["account", "show", "--query", "id", "-o", "tsv"])
    return out if rc == 0 and GUID.match(out) else None

def guard_cloud(tid, meta):
    """The rail: refuse to touch the cloud unless the active subscription is
    the pinned training one. Bootstrap tasks (setup/00) are exempt — creating
    the pin is their job — but everything they grade is still read-only."""
    if meta.get("kind", "local") == "local":
        return
    if meta.get("bootstrap"):
        return
    pin = pinned_sub()
    if not pin:
        die(f"no pinned training subscription in {PIN_FILE}\n"
            f"       complete the setup task first:  {SELF} start setup/00-subscription-safety")
    active = active_sub()
    if not active:
        die("not logged in to az (or no default subscription) — run: az login")
    if active.lower() != pin.lower():
        die(f"active subscription {active[:8]}… is NOT the pinned training subscription "
            f"{pin[:8]}… — refusing to touch it.\n"
            f"       switch with:  az account set -s {pin}")

def guard_paid(meta, flags):
    if meta.get("est_cost") == "free" or meta.get("kind", "local") == "local":
        return
    if meta.get("est_cost") == "paid" and "--i-am-paying" not in flags:
        die("this task creates PAID resources (see meta.json est_cost). "
            "Re-run with --i-am-paying if you accept the cost; teardown promptly.")

def nag_leftovers():
    """Warn (cheaply, cached 30 min) if rg-aztrain-* groups linger from a
    previous session. Best-effort: silent on any az hiccup."""
    pin = pinned_sub()
    if not pin:
        return
    groups, fresh = None, False
    try:
        cache = json.loads(RG_CACHE.read_text())
        if time.time() - cache.get("ts", 0) < 1800:
            groups, fresh = cache.get("groups", []), True
    except (FileNotFoundError, json.JSONDecodeError):
        pass
    if not fresh:
        try:
            if (active_sub() or "").lower() != pin.lower():
                return
            rc, out = az(["group", "list", "--query",
                          f"[?starts_with(name, '{RG_PREFIX}')].name", "-o", "json"], timeout=30)
            if rc != 0:
                return
            groups = json.loads(out)
            RG_CACHE.parent.mkdir(parents=True, exist_ok=True)
            RG_CACHE.write_text(json.dumps({"ts": time.time(), "groups": groups}))
        except Exception:
            return
    if groups:
        print(YEL(f"⚠ leftover training resource groups: {', '.join(sorted(groups))}"))
        print(YEL(f"  they may be costing you money — run: aztrain teardown --all"))

def invalidate_rg_cache():
    RG_CACHE.unlink(missing_ok=True)

# ---- workspace -------------------------------------------------------------
def ws_dir(tid):
    return WORKSPACE / tid

def populate_workspace(tid, meta, force=False):
    """Copy the starter scaffold (if any) into workspace/<tid>."""
    src = meta["_dir"]
    dst = ws_dir(tid)
    if dst.exists() and any(dst.iterdir()) and not force:
        return dst
    if force and dst.exists():
        backup = dst.with_name(dst.name + ".bak")
        shutil.rmtree(backup, ignore_errors=True)
        shutil.copytree(dst, backup)
        shutil.rmtree(dst)
        print(DIM(f"previous work backed up to {backup.relative_to(REPO)}"))
    dst.mkdir(parents=True, exist_ok=True)
    starter = src / "starter"
    if starter.is_dir():
        shutil.copytree(starter, dst, dirs_exist_ok=True)
    return dst

def grader_env(tid, meta):
    env = os.environ.copy()
    env.update({
        "AZTRAIN_REPO": str(REPO),
        "AZTRAIN_TASK_DIR": str(meta["_dir"]),
        "AZTRAIN_WS": str(ws_dir(tid)),
        "AZTRAIN_RG": rg_for(tid),
        "AZTRAIN_LOCATION": LOCATION,
        "AZTRAIN_TASK_ID": tid,
    })
    return env

def run_task_script(tid, meta, name, timeout=None):
    """Run a task's setup.sh / grade.sh / solution.sh with the task env.
    Returns (rc, combined_output)."""
    script = meta["_dir"] / name
    if not script.exists():
        return None, f"(no {name})"
    p = subprocess.run(["bash", str(script)], capture_output=True, text=True,
                       env=grader_env(tid, meta), cwd=str(ws_dir(tid)),
                       stdin=subprocess.DEVNULL,
                       timeout=timeout or meta.get("timeout", 300))
    return p.returncode, (p.stdout + p.stderr).rstrip()

def grade(tid, meta):
    """Grade a task. Local graders run against the workspace; cloud graders
    additionally see AZTRAIN_RG. Returns (passed, output)."""
    ws = ws_dir(tid)
    ws.mkdir(parents=True, exist_ok=True)
    rc, out = run_task_script(tid, meta, "grade.sh")
    if rc is None:
        die(f"task {tid} has no grade.sh — the task is broken, please report it")
    return rc == 0, out

# ---- badges ----------------------------------------------------------------
def badge(meta):
    kind = meta.get("kind", "local")
    cost = meta.get("est_cost", "free")
    if kind == "local":
        return DIM("[local]")
    col = {"free": GRN, "pennies": YEL, "paid": RED}.get(cost, YEL)
    return col(f"[{kind}·{cost}]")

# ---- what to teach next ----------------------------------------------------
# Teaching order for NEW material: gentle fundamentals first, then things that
# build on them, the DevOps (AZ-400) track last. Keyed by a task's domain dir
# (the id minus its leaf, e.g. "az104/storage"); anything unlisted sorts after
# these. Within a domain the nn- prefix already runs easy->hard, so
# (domain rank, id) is the full teaching order.
#
# This is deliberately NOT the exam-blueprint order in docs/objectives.md —
# that mirrors the certification's weighting, not teaching difficulty. A near-
# beginner should meet the material in the order that keeps each step leaning
# only on earlier ones:
#   setup       pin a safe subscription — literally do this first
#   az104/storage    your first resource + Bicep basics (one resource, no wiring)
#   az104/compute    VMs / apps / containers — more resource types, same shape
#   az104/networking VNets / NSGs / peering — wiring resources together
#   az104/identity-governance  RBAC / policy / locks — govern what you can build
#   az104/monitoring KQL / alerts — observe what you built
# then the AZ-400 DevOps track, which assumes you can already describe resources:
#   source-control -> pipelines -> security-compliance -> instrumentation -> processes
DOMAIN_ORDER = {
    "setup": 0,
    "az104/storage": 1, "az104/compute": 2, "az104/networking": 3,
    "az104/identity-governance": 4, "az104/monitoring": 5,
    "az400/source-control": 6, "az400/pipelines": 7,
    "az400/security-compliance": 8, "az400/instrumentation": 9,
    "az400/processes": 10,
}

def curriculum_key(tid):
    """Sort key placing a task in teaching order: (domain rank, then its id)."""
    return (DOMAIN_ORDER.get(domain_of(tid), 99), tid)

def is_done(st, tid):
    return bool(st["tasks"].get(tid, {}).get("passed"))

def cloud_ready():
    """True if the pinned training subscription is the active one — i.e. cloud
    tasks could actually run. Computed once (it calls az) and handed into the
    pure selection functions so they stay testable and side-effect free."""
    pin = pinned_sub()
    if not pin:
        return False
    return (active_sub() or "").lower() == pin.lower()

def selectable(meta, ready):
    """Can autopilot pick this task right now? The subscription-setup bootstrap
    is always surfaced (it's the on-ramp, and train only PRESENTS cloud tasks —
    it never auto-provisions them). Local tasks always. A normal cloud task only
    once the training subscription is active (like redhat gating on a spare
    disk), so a learner who hasn't set Azure up still advances through the local
    Bicep/KQL tasks. Never auto-select a `paid` task: the learner must opt into
    cost explicitly with `aztrain start ... --i-am-paying`."""
    if meta.get("bootstrap"):
        return True
    if meta.get("kind", "local") == "local":
        return True
    if meta.get("est_cost") == "paid":
        return False
    return ready

def due_reviews(tasks, st, ready):
    """Passed tasks whose review date has arrived, most overdue first. A passed
    task with no schedule yet counts as due, so it re-enters the rotation.
    Bootstrap tasks (subscription setup) are one-time — never reviewed."""
    out = []
    for tid, entry in st["tasks"].items():
        if not entry.get("passed"):
            continue
        meta = tasks.get(tid)
        if not meta or meta.get("bootstrap") or not selectable(meta, ready):
            continue
        overdue = days_overdue(entry.get("due"))
        if overdue is None or overdue >= 0:
            out.append((overdue if overdue is not None else 0, tid, meta))
    out.sort(key=lambda x: -x[0])           # most overdue first
    return [(tid, meta) for _, tid, meta in out]

def next_new(tasks, st, ready):
    """First not-yet-passed task in teaching order (fundamentals first). An
    attempted-but-unpassed task counts as not-done, so this resumes work."""
    for tid in sorted(tasks, key=curriculum_key):
        if is_done(st, tid):
            continue
        if not selectable(tasks[tid], ready):
            continue
        return tid, tasks[tid]
    return None

def soonest_review(tasks, st):
    """The nearest upcoming (not-yet-due) review, as (days_away, tid, meta)."""
    best = None
    for tid, entry in st["tasks"].items():
        if not entry.get("passed"):
            continue
        meta = tasks.get(tid)
        due = entry.get("due")
        if not meta or meta.get("bootstrap") or not due:
            continue
        away = -days_overdue(due)
        if away > 0 and (best is None or away < best[0]):
            best = (away, tid, meta)
    return best

def choose_task(tasks, st, ready):
    """Decide what to practise next. Pure — no side effects, so it's testable.
    Returns (tid, meta, kind, reason). kind is 'review', 'new', or None.

    Reviews take priority once due, but never more than two in a row while new
    material is still waiting, so new content always keeps advancing."""
    reviews = due_reviews(tasks, st, ready)
    new = next_new(tasks, st, ready)
    recent = st.get("recent_picks", [])
    review_wall = len(recent) >= 2 and recent[-1] == "review" and recent[-2] == "review"

    if reviews and not (review_wall and new):
        (tid, meta), kind = reviews[0], "review"
    elif new:
        (tid, meta), kind = new, "new"
    elif reviews:                       # only reviews left (all new material done)
        (tid, meta), kind = reviews[0], "review"
    else:
        return None, None, None, ""

    if kind == "review":
        overdue = days_overdue(st["tasks"][tid].get("due"))
        reason = "due for review" if not overdue else f"review — {overdue}d overdue"
    elif st["tasks"].get(tid, {}).get("attempts"):
        reason = "resume — started but not yet passed"
    else:
        reason = "new material, next in sequence"
    return tid, meta, kind, reason

# ---- commands ----------------------------------------------------------------
def print_status_line(st):
    done = sum(1 for t in st["tasks"].values() if t.get("passed"))
    streak = st["streak"]["count"]
    unit = "day" if streak == 1 else "days"
    print(f"{BLD('XP')} {st['xp']}   {BLD('Streak')} {streak} {unit}   {BLD('Done')} {done}")

def cmd_list(args):
    tasks = discover()
    st = load_state()
    only = args[0].strip("/") if args else None
    nag_leftovers()
    domains = {}
    for tid, meta in tasks.items():
        domains.setdefault(domain_of(tid), []).append((tid, meta))
    known = set(domains) | {d.split("/")[0] for d in domains}
    if only and only not in known:
        die(f"no track/domain '{only}' (have: {', '.join(sorted(known))})")
    for dom in sorted(domains):
        if only and dom != only and not dom.startswith(only + "/"):
            continue
        rows = domains[dom]
        done = sum(1 for tid, _ in rows if st["tasks"].get(tid, {}).get("passed"))
        print(f"\n{BLD(BLU(dom))} {DIM(f'({done}/{len(rows)})')}")
        for tid, meta in rows:
            rec = st["tasks"].get(tid, {})
            mark = GRN("✓") if rec.get("passed") else (YEL("…") if rec.get("attempts") else DIM("·"))
            stars = MAG("★" * meta.get("difficulty", 1))
            print(f"  {mark} {leaf_of(tid):<32} {stars:<18} {badge(meta):<24} "
                  f"{DIM(str(meta.get('est_min', '?')) + 'm')}  {meta['title']}")
    if not only:
        total = len(tasks)
        done = sum(1 for t in tasks if st["tasks"].get(t, {}).get("passed"))
        print(f"\n{BLD(f'{done}/{total} tasks complete')} — "
              f"{st['xp']} XP, {st['streak']['count']}-day streak")
        print(DIM("New to this?  ") + BLD(f"{INVOKE} learn")
              + DIM("  teaches the next one first."))
        print(DIM("Know it already?  ") + BLD(f"{INVOKE} train")
              + DIM("  just picks what to practise."))

def show_spec(tid, meta, ws):
    """Print a task's header, badge and prompt, plus its workspace / RG."""
    print(BLD(f"\n=== {meta['title']} ") + DIM(f"[{tid}]") + " " + badge(meta))
    print(DIM(f"difficulty {'★' * meta.get('difficulty', 1)} · ~{meta.get('est_min', '?')} min"
              f" · objective: {meta.get('objective', '?')}"))
    print()
    print((meta["_dir"] / "prompt.md").read_text())
    print(BLD("Your workspace: ") + str(ws.relative_to(REPO)) + "/")
    if meta.get("kind") == "live":
        print(BLD("Resource group: ") + rg_for(tid)
              + DIM(f"  (destroy later with: {SELF} teardown {leaf_of(tid)})"))

def mark_current(st, tid):
    """Record this as the task check/solution/reset default to, and note it's
    started (attempts stays 0 until a real check) so train can 'resume' it."""
    st["tasks"].setdefault(tid, {"passed": False, "attempts": 0})
    st["current"] = tid
    save_state(st)

def launch_task(st, tid, meta, flags=(), provision=True):
    """Set a task up and show its spec; mark it current. Shared by `start` and
    (for local tasks) `train`. With provision=False the cloud-mutating setup.sh
    is NOT run — used when `train` surfaces a cloud task, so the learner triggers
    the billable provisioning themselves via `aztrain start`."""
    kind = meta.get("kind", "local")
    if provision:
        guard_paid(meta, flags)
        guard_cloud(tid, meta)
        if kind in ("whatif", "live"):
            nag_leftovers()
    ws = populate_workspace(tid, meta)
    if provision and (meta["_dir"] / "setup.sh").exists():
        print(DIM(f"running setup for {tid} "
                  + (f"(resource group {rg_for(tid)})..." if kind == "live" else "...")))
        rc, out = run_task_script(tid, meta, "setup.sh")
        invalidate_rg_cache()
        if rc != 0:
            print(out)
            die(f"setup failed for {tid} — nothing to do until that's fixed "
                f"(re-run start; teardown if it half-created things)")
    show_spec(tid, meta, ws)
    mark_current(st, tid)
    if provision:
        print(DIM("When ready:     ") + f"{INVOKE} check"
              + DIM(f"   (or: {SELF} check {tid})"))
    else:
        print(YEL("\nThis task provisions real Azure resources, so aztrain won't "
                  "do it automatically."))
        print(DIM("Start it yourself when ready:  ") + f"{SELF} start {leaf_of(tid)}"
              + DIM(f"  (creates {rg_for(tid)})"))
        print(DIM("Then grade with:               ") + f"{INVOKE} check")

def cmd_start(args):
    flags = [a for a in args if a.startswith("--")]
    args = [a for a in args if not a.startswith("--")]
    if not args:
        die(f"usage: {SELF} start <id>   (or just: {INVOKE} train)")
    tasks = discover()
    st = load_state()
    tid = resolve(tasks, args[0])
    launch_task(st, tid, tasks[tid], flags, provision=True)

# ---- train: autopilot ------------------------------------------------------
def cmd_train(args):
    tasks = discover()
    if not tasks:
        print(DIM("no tasks found")); return
    st = load_state()
    ready = cloud_ready()
    nag_leftovers()
    tid, meta, kind, reason = choose_task(tasks, st, ready)
    if tid is None:
        print()
        print(GRN(BLD("All caught up — nothing due and no new tasks.")))
        nxt = soonest_review(tasks, st)
        if nxt:
            print(DIM(f"Next review ({nxt[2]['title']}) comes due in {nxt[0]}d."))
        if not ready and any(m.get("kind") != "local" and not m.get("bootstrap")
                             and not is_done(st, t) for t, m in tasks.items()):
            print(DIM("Cloud tasks are waiting — activate your training subscription "
                      "to unlock them:  ") + f"{SELF} start setup/00-subscription-safety")
        print()
        print_status_line(st)
        return
    st["recent_picks"] = (st.get("recent_picks", []) + [kind])[-4:]
    save_state(st)
    tag = YEL("REVIEW") if kind == "review" else GRN(" NEW  ")
    print()
    print_status_line(st)
    print(f"{tag}  {DIM(reason)}")
    # Local tasks are set up in full. Cloud tasks are only PRESENTED — the
    # learner provisions them (their own az login, their own bill), never train.
    if meta.get("kind", "local") == "local":
        launch_task(st, tid, meta, provision=True)
    else:
        if kind == "review":
            print(DIM("(a cloud review — re-provision it yourself when you want to redo it)"))
        launch_task(st, tid, meta, provision=False)

def cmd_check(args):
    flags = [a for a in args if a.startswith("--")]
    args = [a for a in args if not a.startswith("--")]
    tasks = discover()
    st = load_state()
    ident = args[0] if args else st.get("current")
    if not ident:
        die(f"nothing to check — run '{INVOKE} train' first, "
            f"or name a task: {SELF} check <id>")
    tid = resolve(tasks, ident)
    meta = tasks[tid]
    guard_paid(meta, flags)
    guard_cloud(tid, meta)
    passed, output = grade(tid, meta)
    rec = st["tasks"].setdefault(tid, {"passed": False, "attempts": 0})
    rec["attempts"] += 1
    print(output)
    if passed:
        was_review = rec.get("passed", False)
        print(GRN(BLD("PASS")) + f" — {meta['title']}")
        if was_review:
            reps, xp = rec.get("reps", 1) + 1, 5     # cheaper: you already knew it
        else:
            reps, xp = 1, XP_BY_DIFFICULTY.get(meta.get("difficulty", 1), 10)
        rec["passed"] = True
        st["xp"] += xp
        bump_streak(st)
        print(GRN(f"+{xp} XP") + DIM(f"  (total {st['xp']}, streak {st['streak']['count']})"))
        if not meta.get("bootstrap"):
            schedule_review(rec, reps)
            print(DIM(f"Next review in {review_interval(reps)}d.  Next task:  ")
                  + f"{INVOKE} train")
        if meta.get("kind") == "live":
            print(YEL(f"remember: {SELF} teardown {leaf_of(tid)}  "
                      "(the RG keeps existing until you do)"))
    else:
        if rec.get("passed"):        # a lapse — relearn from the start, soon
            rec["reps"] = 0
            rec["due"] = date.today().isoformat()
        print(RED(BLD("FAIL")) + f" — {meta['title']}")
        print(DIM("Fix it and re-run  ") + f"{INVOKE} check"
              + DIM(f"   (stuck?  {SELF} solution {tid})"))
    save_state(st)
    if not passed:
        sys.exit(1)

